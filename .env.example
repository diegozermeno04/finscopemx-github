# Database
DATABASE_URL=postgresql+asyncpg://user:password@localhost:5432/finscope

# Authentication
SECRET_KEY=your_secret_key_here
ACCESS_TOKEN_EXPIRE_MINUTES=30

# Optional: Redis (for Celery)
REDIS_URL=redis://localhost:6379/0

# Optional: Yahoo Finance (for data fetching)
YAHOO_FINANCE_COOKIE=your_cookie_here

# Optional: Frontend API URL
VITE_API_BASE_URL=/api
